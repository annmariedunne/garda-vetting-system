@page
@model GardaVettingSystem.Pages.Applicants.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Applicant</h4>
    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Applicant.ApplicantNumber" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil-fill"></i> Edit
        </a>
    </div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.FirstName):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.FirstName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.LastName):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.LastName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.BirthLastName):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.BirthLastName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.MothersLastName):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.MothersLastName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.Gender):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.Gender)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.DateOfBirth):
        </dt>
        <dd class="col-sm-10">
            @Model.Applicant.DateOfBirth?.ToString("d")
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Applicant.BirthPlace):
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Applicant.BirthPlace)
        </dd>
    </dl>
</div>
<div class="mt-4">
    <h4>Address History</h4>
    <div>
        <a asp-page="/ApplicantAddresses/Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle-fill"></i> Add Address
        </a>
    </div>
    <hr />
    @if (Model.Applicant.ApplicantAddresses != null && Model.Applicant.ApplicantAddresses.Any())
    {
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Address</th>
                    <th>Postcode</th>
                    <th>Country</th>
                    <th>From</th>
                    <th>To</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var address in Model.Applicant.ApplicantAddresses)
                {
                    <tr>
                        <td>@address.AddressLine</td>
                        <td>@address.Postcode</td>
                        <td>@address.Country</td>
                        <td>@address.ResidentFrom</td>
                        <td>@(address.ResidentTo.HasValue? address.ResidentTo.ToString() : "Current")</td>
                        <td class="align-middle">
                            <a asp-page="/ApplicantAddresses/Edit" asp-route-id="@address.AddressId" class="btn btn-primary btn-sm">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <a asp-page="/ApplicantAddresses/Delete" asp-route-id="@address.AddressId" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No addresses added yet.</p>
    }
</div>
<div class="mt-4">
    <h4>Access Codes</h4>
    <div>
        <a asp-page="/AccessCodes/Create" class="btn btn-info btn-sm">
            <i class="bi bi-key-fill"></i> Generate Access Code
        </a>
    </div>
    <hr />
    @if (Model.Applicant.AccessCodes != null && Model.Applicant.AccessCodes.Any())
    {
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Organisation</th>
                    <th>Created</th>
                    <th>Expires</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var code in Model.Applicant.AccessCodes)
                {
                    <tr>
                        <td><strong>@code.Code</strong></td>
                        <td>@code.OrganisationName</td>
                        <td>@code.CreatedDate.ToString("d")</td>
                        <td>@(code.ExpiryDate.HasValue? code.ExpiryDate.Value.ToString("d") : "No expiry")</td>
                        <td class="align-middle">
                            @if (!code.IsActive)
                            {
                                <span class="badge bg-secondary">Revoked</span>
                            }
                            else if (code.ExpiryDate.HasValue && code.ExpiryDate.Value < DateTimeOffset.UtcNow)
                            {
                                <span class="badge bg-warning text-white">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td class="align-middle">
                            @if (code.IsActive && (!code.ExpiryDate.HasValue || code.ExpiryDate.Value > DateTimeOffset.UtcNow))
                            {
                                <a asp-page="/AccessCodes/Delete" asp-route-id="@code.AccessCodeId" class="btn btn-danger btn-sm">
                                    <i class="bi bi-x-circle-fill"></i> Revoke
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No access codes generated yet.</p>
    }
</div>
<div>
    <a asp-page="./Delete" asp-route-id="@Model.Applicant.ApplicantNumber" class="btn btn-danger btn-sm">
        <i class="bi bi-trash-fill"></i> Delete My Profile
    </a>
</div>
