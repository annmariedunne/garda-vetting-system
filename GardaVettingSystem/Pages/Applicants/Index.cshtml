@page
@model GardaVettingSystem.Pages.Applicants.IndexModel

@{
    ViewData["Title"] = "Profile Deleted";
}

<div class="text-center mt-5">
    <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
    <h1 class="mt-3">Profile Deleted</h1>
    <p class="text-muted mt-3">Your applicant profile and all associated data has been permanently removed.</p>
    <p class="text-muted">You can create a new profile or log out.</p>
    <div class="mt-4">
        <a asp-page="/Applicants/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-person-plus-fill"></i> Create New Profile
        </a>
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </form>
    </div>
</div>

<div class="mt-3">
    <hr />
    <p class="text-muted small">Want to completely remove your account including your email address?</p>
    <form method="post" asp-page="/Applicants/Index">
        <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-person-x-fill"></i> Delete My Account Completely
        </button>
    </form>
</div>
