@page
@model GardaVettingSystem.Pages.AccessCodes.ValidateModel

@{
    ViewData["Title"] = "Validate";
}

<h1>Validate</h1>

<h4>AccessCode</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AccessCode.AccessCodeId" />
            <div class="form-group">
                <label asp-for="AccessCode.ApplicantNumber" class="control-label"></label>
                <select asp-for="AccessCode.ApplicantNumber" class="form-control" asp-items="ViewBag.ApplicantNumber" ></select>
                <span asp-validation-for="AccessCode.ApplicantNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AccessCode.Code" class="control-label"></label>
                <input asp-for="AccessCode.Code" class="form-control" aria-required="true"/>
                <span asp-validation-for="AccessCode.Code" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AccessCode.OrganisationName" class="control-label"></label>
                <input asp-for="AccessCode.OrganisationName" class="form-control" aria-required="true"/>
                <span asp-validation-for="AccessCode.OrganisationName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AccessCode.CreatedDate" class="control-label"></label>
                <input asp-for="AccessCode.CreatedDate" class="form-control" />
                <span asp-validation-for="AccessCode.CreatedDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AccessCode.ExpiryDate" class="control-label"></label>
                <input asp-for="AccessCode.ExpiryDate" class="form-control" />
                <span asp-validation-for="AccessCode.ExpiryDate" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AccessCode.IsActive" /> @Html.DisplayNameFor(model => model.AccessCode.IsActive)
                </label>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
