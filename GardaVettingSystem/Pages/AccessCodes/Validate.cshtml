@page
@model GardaVettingSystem.Pages.AccessCodes.ValidateModel

@{
    ViewData["Title"] = "Validate Access Code";
}

<h1>Validate Access Code</h1>
<p class="text-muted">Enter the access code provided by the applicant to view their vetting data.</p>
<hr />

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="EnteredCode" class="control-label">Access Code</label>
                <input asp-for="EnteredCode" class="form-control" placeholder="Enter 12-character code" aria-required="true" />
                <span asp-validation-for="EnteredCode" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search"></i> Validate
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage
    </div>
}

@if (Model.FoundApplicant != null)
{
    <div class="mt-4">
        <h4 class="text-success"><i class="bi bi-check-circle-fill"></i> Valid Access Code</h4>
        <hr />
        <h5>Personal Details</h5>
        <dl class="row">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.FullName</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.DateOfBirth?.ToString("d")</dd>

            <dt class="col-sm-3">Gender</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.Gender</dd>

            <dt class="col-sm-3">Place of Birth</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.BirthPlace</dd>

            <dt class="col-sm-3">Surname at Birth</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.BirthLastName</dd>

            <dt class="col-sm-3">Mother's Last Name</dt>
            <dd class="col-sm-9">@Model.FoundApplicant.MothersLastName</dd>
        </dl>

        <h5 class="mt-4">Address History</h5>
        @if (Model.FoundApplicant.ApplicantAddresses != null && Model.FoundApplicant.ApplicantAddresses.Any())
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Address</th>
                        <th>Postcode</th>
                        <th>Country</th>
                        <th>From</th>
                        <th>To</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var address in Model.FoundApplicant.ApplicantAddresses)
                    {
                        <tr>
                            <td>@address.AddressLine</td>
                            <td>@address.Postcode</td>
                            <td>@address.Country</td>
                            <td>@address.ResidentFrom</td>
                            <td>@(address.ResidentTo.HasValue? address.ResidentTo.ToString() : "Current")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No address history available.</p>
        }
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
