@page
@model GardaVettingSystem.Pages.AccessCodes.CreateModel

@{
    ViewData["Title"] = "Generate Access Code";
}

<h1>Generate Access Code</h1>
<h4>Enter the organisation name to generate a secure access code.</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="AccessCode.OrganisationName" class="control-label"></label>
                <input asp-for="AccessCode.OrganisationName" class="form-control" aria-required="true" />
                <span asp-validation-for="AccessCode.OrganisationName" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-info btn-sm">
                    <i class="bi bi-key-fill"></i> Generate Code
                </button>
                <a asp-page="/Applicants/Details" asp-route-id="@Model.ApplicantNumber" class="btn btn-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
