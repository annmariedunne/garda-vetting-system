@page
@model GardaVettingSystem.Pages.ApplicantAddresses.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>ApplicantAddress</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicantAddress.AddressLine)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicantAddress.AddressLine)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicantAddress.Postcode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicantAddress.Postcode)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicantAddress.Country)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicantAddress.Country)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicantAddress.ResidentFrom)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicantAddress.ResidentFrom)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicantAddress.ResidentTo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicantAddress.ResidentTo)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="ApplicantAddress.AddressId" />
        <div class="form-group mt-3">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-trash-fill"></i> Delete
            </button>
            <a asp-page="/Applicants/Details" asp-route-id="@Model.ApplicantAddress.ApplicantNumber" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>
        </div>
    </form>
</div>
