      "Title": "GardaVettingSystem.Pages.Applicants.CreateModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.Applicants.CreateModel.yml\" sourcestartlinenumber=\"1\">Handles the creation of a new applicant profile for the logged-in user.</p>\n<p>Each user can only have one profile — if one already exists, the user is\nredirected to Edit instead.</p>\n"
    },
    {
      "type": "ManagedReference",
      "source_relative_path": "api/GardaVettingSystem.Pages.Applicants.DeleteModel.yml",
      "output": {
        ".html": {
