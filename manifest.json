        }
      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "GardaVettingSystem.Pages.Applicants.DeleteModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.Applicants.DeleteModel.yml\" sourcestartlinenumber=\"1\">Handles the deletion of the logged-in user's applicant profile.</p>\n<p>Ownership is verified server-side — users can only delete their own profile.</p>\n<p>After deletion the user is redirected to the application root as they no longer have a profile.</p>\n"
    },
