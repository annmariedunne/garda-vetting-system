      "Uid": null,
      "IsMRef": true,
      "Title": "GardaVettingSystem.Pages.AccessCodes.DeleteModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.AccessCodes.DeleteModel.yml\" sourcestartlinenumber=\"1\">Handles revocation of an access code for the logged-in applicant.</p>\n<p>Revocation sets IsActive to false rather than deleting the record,\npreserving the audit trail in line with GDPR accountability principles.</p>\n"
    },
    {
      "type": "ManagedReference",
      "source_relative_path": "api/GardaVettingSystem.Pages.AccessCodes.ValidateModel.yml",
      "output": {
        ".html": {
          "relative_path": "api/GardaVettingSystem.Pages.AccessCodes.ValidateModel.html"
        }
      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "GardaVettingSystem.Pages.AccessCodes.ValidateModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.AccessCodes.ValidateModel.yml\" sourcestartlinenumber=\"1\">Handles validation of an access code entered by an organisation.</p>\n<p>This is a public page — no authentication is required.</p>\n<p>An organisation enters a code to view the associated applicant's vetting data,\nprovided the code is active and has not expired.</p>\n"
    },
