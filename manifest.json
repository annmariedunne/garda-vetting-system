      "Title": "GardaVettingSystem.Pages.AccessCodes.CreateModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.AccessCodes.CreateModel.yml\" sourcestartlinenumber=\"1\">Handles the generation of a new access code for the logged-in applicant.</p>\n<p>The applicant provides an organisation name; all other fields are set server-side.</p>\n"
    },
    {
      "type": "ManagedReference",
      "source_relative_path": "api/GardaVettingSystem.Pages.AccessCodes.DeleteModel.yml",
      "output": {
        ".html": {
          "relative_path": "api/GardaVettingSystem.Pages.AccessCodes.DeleteModel.html"
