      "IsMRef": true,
      "Title": "GardaVettingSystem.Pages.ApplicantAddresses.CreateModel",
      "Summary": "<p sourcefile=\"api/GardaVettingSystem.Pages.ApplicantAddresses.CreateModel.yml\" sourcestartlinenumber=\"1\">Handles the creation of a new address for the logged-in applicant.</p>\n<p>ApplicantNumber is always set server-side from the logged-in user's identity —\nit is never accepted from the form to prevent cross-user data manipulation.</p>\n"
    },
    {
      "type": "ManagedReference",
      "source_relative_path": "api/GardaVettingSystem.Pages.ApplicantAddresses.DeleteModel.yml",
      "output": {
        ".html": {
